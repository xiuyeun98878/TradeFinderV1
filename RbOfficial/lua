-- Fake Loading Messages
local messages = {
	"Analyzing trade data",
	"Loading inventories",
	"Syncing values",
	"Scanning servers",
	"Configuring assets",
	"Preparing UI",
	"Checking player data",
	"Optimizing trades",
	"Fetching market values"
}

-- Infinite Fake Status Animation
task.spawn(function()
	local index = 1

	while true do
		local msg = messages[index]

		for i = 1,3 do
			status.Text = msg .. string.rep(".", i)
			task.wait(0.5)
		end

		index += 1
		if index > #messages then
			index = 1
		end
	end
end)

-- Fake Progress Animation
task.spawn(function()
	local fakeProgress = 92

	while true do
		fakeProgress += math.random(0,1) * 0.1

		if fakeProgress >= 98 then
			fakeProgress = 96.8
		end

		fill.Size = UDim2.new(fakeProgress/100,0,1,0)
		percent.Text = math.floor(fakeProgress) .. "%"

		task.wait(0.15)
	end
end)

-- Shine Animation
task.spawn(function()
	while true do
		shine.Position = UDim2.new(-0.2,0,0,0)

		for i = -0.2,1.2,0.02 do
			shine.Position = UDim2.new(i,0,0,0)
			task.wait(0.01)
		end

		task.wait(1)
	end
end)

-- Rotating Gradient
